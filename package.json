{
  "name": "cloud-notebook",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "setup:dev": "pnpm --filter backend exec node scripts/setup-dev.mjs",
    "deploy:full": "pnpm run setup:production && pnpm run deploy",
    "setup:production": "pnpm --filter backend exec node scripts/setup-production.mjs",
    "setup:secrets": "pnpm --filter backend exec node scripts/setup-secrets.mjs",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "version": "1.0.0",
  "main": "index.js",
  "repository": "https://github.com/SoraKumo001/cloud-notebook",
  "author": "SoraKumo <info@croud.jp>",
  "license": "MIT"
}
