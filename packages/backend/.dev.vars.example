# packages/backend/.dev.vars.example
# Copy this file to .dev.vars and fill in your local development values.
# .dev.vars is loaded by `wrangler dev` and is git-ignored.
#
# For production deployment, set these as Wrangler Secrets instead.
# See docs/deployment.md for details.

# ---- Development mode (required) ----
# When set to "development", the auth middleware returns a dummy user
# (dev-user@example.com) instead of validating the session cookie.
NODE_ENV=development
# Optional: explicitly bypass auth (works regardless of NODE_ENV).
# CF_DEV_BYPASS_AUTH=1

# ---- Session secret (required in production) ----
# 32-byte base64 string used to HMAC-sign session cookies.
# Generate with: openssl rand -base64 32
# Required when NODE_ENV is NOT "development" (otherwise login will fail).
SESSION_SECRET=MTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTI=

# ---- API key encryption master key (required for L5 features) ----
# Generate with: openssl rand -base64 32
# Dummy 32-byte base64 key for local development — DO NOT use this in production.
API_KEY_ENCRYPTION_MASTER=MTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTI=
