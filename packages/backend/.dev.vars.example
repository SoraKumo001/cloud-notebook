# packages/backend/.dev.vars.example
# Copy this file to .dev.vars and fill in your local development values.
# .dev.vars is loaded by `wrangler dev` and is git-ignored.
#
# For production deployment, set these as Wrangler Secrets instead.
# See docs/development.md for the local setup workflow.

# ---- Development mode ----
# When set to "development", the onError handler exposes stack traces in 500
# responses and the /local-uploads dev proxy is enabled. This no longer
# bypasses authentication — you must register a user via /api/auth/register
# before protected routes will work.
NODE_ENV=development

# ---- Session secret (required in production) ----
# 32-byte base64 string used to HMAC-sign session cookies.
# Generate with: openssl rand -base64 32
# Always required: login and any protected route will fail if this is unset.
# Generate with: openssl rand -base64 32
SESSION_SECRET=eAD9hTPUIwPYsMXHchOxjKvzbHKqWyaOCfJfAZKOkQc=

# ---- API key encryption master key (required for L5 features) ----
# Generate with: openssl rand -base64 32
# Dummy 32-byte base64 key for local development — DO NOT use this in production.
API_KEY_ENCRYPTION_MASTER=MTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTI=

# ---- Cloudflare Credentials (Optional) ----
# Required ONLY if you want to dynamically fetch the available Workers AI models
# from the Cloudflare API. If unset, the backend falls back to models.json.
# CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
